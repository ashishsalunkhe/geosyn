#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="${1:-}"
if [[ -z "${MSG_FILE}" || ! -f "${MSG_FILE}" ]]; then
  exit 0
fi

FIRST_LINE="$(head -n 1 "${MSG_FILE}" || true)"
if ! printf '%s' "${FIRST_LINE}" | grep -qE '[A-Z][A-Z0-9]+-[0-9]+'; then
  echo "Commit message must include a Jira issue key like GEOSYN-0028." >&2
  echo "Example: GEOSYN-0028: Short task description" >&2
  exit 1
fi
